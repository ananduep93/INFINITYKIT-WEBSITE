rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@infinitykit.com' ||
        request.auth.token.email == 'ananduep93@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Survey Hub Rules
    match /tools/surveyHub/{userId}/{surveyId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /tools/surveyResponses/{surveyId}/{responseId} {
      allow read: if isAdmin() || (request.auth != null && exists(/databases/$(database)/documents/tools/surveyHub/$(request.auth.uid)/$(surveyId)));
      allow create: if request.resource.data.keys().hasAll(['timestamp']) && 
                      request.resource.data.size() < 50; // Basic validation
    }

    // What's New Updates - Protected
    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Affiliate Ads - Protected
    match /affiliateAds/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // AI Prompts - Protected
    match /aiPrompts/{promptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews - Public read/create, Admin manage
    match /reviews/{reviewId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Generic rule for any other collection (Deny by default)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
