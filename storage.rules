rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@infinitykit.com'
      );
    }

    // Helper for validating images
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isSmallFile() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // Survey Hub Storage Rules
    match /surveys/{userId}/{fileName} {
      // Only owner or admin can write
      allow write: if (request.auth != null && request.auth.uid == userId && isImage() && isSmallFile()) || isAdmin();
      // Public read access for survey images
      allow read: if true;
    }

    // User profile images
    match /users/{userId}/profile/{fileName} {
      allow write: if (request.auth != null && request.auth.uid == userId && isImage() && isSmallFile()) || isAdmin();
      allow read: if true;
    }

    // Default: Deny everything else
    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
